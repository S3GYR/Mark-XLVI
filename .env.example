# JARVIS environment configuration

# LLM provider and model (LiteLLM format)
JARVIS_LLM_PROVIDER=gemini
JARVIS_LLM_MODEL=gemini/gemini-2.5-flash
JARVIS_LLM_FALLBACK_MODEL=openai/gpt-4o-mini

# API keys (optional if stored in keyring)
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=

# Audio
JARVIS_AUDIO_SEND_SAMPLE_RATE=16000
JARVIS_AUDIO_RECEIVE_SAMPLE_RATE=24000

# Dashboard
JARVIS_DASHBOARD_HOST=127.0.0.1
JARVIS_DASHBOARD_PORT=8000
JARVIS_DASHBOARD_AUTO_FIREWALL=false

# Security
JARVIS_REQUIRE_CONFIRMATION=true
JARVIS_SANDBOX_ENABLED=true

# Memory
JARVIS_MEMORY_BACKEND=postgres
JARVIS_POSTGRES_URL=postgresql://jarvis:jarvis@localhost:5432/jarvis
JARVIS_VECTOR_DIM=768

# Logging
JARVIS_LOG_LEVEL=INFO
